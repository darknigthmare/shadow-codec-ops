{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Shadow Codec Ops",
  "version": "1.0.0",
  "identifier": "com.darknigthmare.shadowcodecops",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Shadow Codec Ops",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
